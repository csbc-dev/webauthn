{
  "name": "@csbc-dev/webauthn",
  "version": "0.4.0",
  "description": "Declarative WebAuthn / Passkeys component for Web Components. Server-side challenge + verification, browser-native credentials.create()/.get(), via wc-bindable-protocol.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    },
    "./server": {
      "types": "./dist/server/index.d.ts",
      "default": "./dist/server/index.js"
    }
  },
  "files": [
    "dist",
    "LICENSE",
    "README.md"
  ],
  "scripts": {
    "prepack": "npm run build",
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "npm run test:unit",
    "test:watch": "npm run test:unit:watch",
    "test:coverage": "npm run test:unit:coverage",
    "test:unit": "vitest run __tests__",
    "test:unit:watch": "vitest __tests__",
    "test:unit:coverage": "vitest run __tests__ --coverage",
    "test:integration": "npm run build && playwright test"
  },
  "keywords": [
    "web-components",
    "webauthn",
    "passkey",
    "passwordless",
    "fido2",
    "custom-elements",
    "wc-bindable",
    "declarative",
    "framework-agnostic"
  ],
  "peerDependencies": {
    "@simplewebauthn/server": "^11.0.0"
  },
  "peerDependenciesMeta": {
    "@simplewebauthn/server": {
      "optional": true
    }
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "@vitest/coverage-v8": "^4.1.4",
    "happy-dom": "^20.8.3",
    "typescript": "^5.9.3",
    "vitest": "^4.0.18"
  },
  "author": "mogera551",
  "repository": {
    "type": "git",
    "url": "https://github.com/mogera551/csbc-dev.git",
    "directory": "webauthn"
  },
  "license": "MIT",
  "engines": {
    "node": ">=20"
  },
  "dependencies": {}
}
